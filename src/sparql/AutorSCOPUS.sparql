PREFIX cti: <http://gic.ufrpe.br/cti/vocabulary/cti#>

SELECT ?id ?nomeAutor ?tituloArtigo ?doi
WHERE {
  # Buscamos instâncias que são do tipo Autor
  ?autor a cti:Autor ;
         cti:id_pessoa ?id ;
         cti:nm_pessoa ?nomeAutor ;
         cti:autoria ?artigo .

  # Pegamos os dados do artigo vinculado
  ?artigo cti:nm_titulo ?tituloArtigo .
  
  # Opcional: pegar o DOI se existir
  OPTIONAL { ?artigo cti:ds_doi ?doi }

  # Filtro lógico: Queremos ver apenas quem NÃO foi classificado como Docente ou Discente ainda
  FILTER NOT EXISTS { ?autor a cti:Docente }
  FILTER NOT EXISTS { ?autor a cti:Discente }
}
ORDER BY ?nomeAutor
